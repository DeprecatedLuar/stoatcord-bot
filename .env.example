# Secrets only — non-secret config lives in compose.yaml.
# See compose.yaml for STOAT_API_BASE, STOAT_WS_URL, PUSH_ENABLED, etc.

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Stoat/Revolt bot token (from app settings or bot page)
STOAT_TOKEN=

# API key for HTTP API auth (shared secret with Stoat app, leave blank to disable)
API_KEY=

# VAPID keys for UnifiedPush/WebPush (generate with: bun -e "console.log(require('web-push').generateVAPIDKeys())")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Firebase service account JSON as a string — alternative to mounting the file
# at .data/firebase-service-account.json (see compose.yaml)
# FIREBASE_SA_JSON={"type":"service_account",...}
